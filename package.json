{
  "name": "themanager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node app/server/index.js",
    "client": "cd app/client && npm run dev",
    "build": "cd app/client && npm run build",
    "install:all": "npm install && cd app/client && npm install && cd ../server && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
